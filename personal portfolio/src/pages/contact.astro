---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact | Marco Trento"
  description="Contact Marco Trento via email, phone, LinkedIn, or GitHub."
  active="contact"
>
  <section class="section reveal" style="margin-top:0;">
    <h2>Contact</h2>
    <p class="page-intro">
      I’m always open to new opportunities and conversations. Reach out!
    </p>

    <div class="contact-grid">
      <a class="contact-card" href="mailto:trento.marco23@gmail.com">
        <span class="icon-badge" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
            <path d="M3 7l9 6 9-6"></path>
          </svg>
        </span>
        <span class="contact-detail">
          <span>Email</span>
          <strong>trento.marco23@gmail.com</strong>
        </span>
      </a>

      <a class="contact-card" href="tel:+393663290707">
        <span class="icon-badge" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.9 19.9 0 0 1-8.7-3.1 19.5 19.5 0 0 1-6-6A19.9 19.9 0 0 1 2 4.1 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1.9.4 1.8.7 2.6a2 2 0 0 1-.4 2.1L8 9.8a16 16 0 0 0 6.2 6.2l1.4-1.3a2 2 0 0 1 2.1-.4c.8.3 1.7.5 2.6.7A2 2 0 0 1 22 16.9z"></path>
          </svg>
        </span>
        <span class="contact-detail">
          <span>Phone</span>
          <strong>+39 3663290707</strong>
        </span>
      </a>

      <a class="contact-card" href="https://www.linkedin.com/in/marco-trento" target="_blank" rel="noopener noreferrer">
        <span class="icon-badge" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.94 8.7H3.56V20h3.38V8.7Zm.22-3.48a1.96 1.96 0 1 0-3.92 0 1.96 1.96 0 0 0 3.92 0ZM20 13.4c0-3.3-1.76-4.84-4.1-4.84-1.89 0-2.74 1.03-3.22 1.76V8.7H9.3V20h3.38v-5.6c0-1.47.28-2.89 2.1-2.89 1.8 0 1.82 1.68 1.82 2.99V20H20v-6.6Z"></path>
          </svg>
        </span>
        <span class="contact-detail">
          <span>LinkedIn</span>
          <strong>linkedin.com/in/marco-trento</strong>
        </span>
      </a>

      <a class="contact-card" href="https://github.com/marco-trento" target="_blank" rel="noopener noreferrer">
        <span class="icon-badge" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.25.82-.57v-2.18c-3.35.73-4.05-1.42-4.05-1.42-.55-1.37-1.33-1.73-1.33-1.73-1.09-.73.08-.72.08-.72 1.2.08 1.84 1.2 1.84 1.2 1.08 1.81 2.82 1.29 3.51.99.11-.76.42-1.29.77-1.59-2.67-.3-5.47-1.3-5.47-5.85 0-1.3.47-2.37 1.23-3.2-.12-.3-.53-1.52.12-3.16 0 0 1.01-.32 3.3 1.22A11.6 11.6 0 0 1 12 6.53c1.02 0 2.04.14 3 .41 2.29-1.54 3.3-1.22 3.3-1.22.66 1.64.25 2.86.12 3.16.77.83 1.23 1.9 1.23 3.2 0 4.56-2.81 5.54-5.49 5.84.43.37.81 1.08.81 2.19v3.25c0 .32.22.69.83.57A12 12 0 0 0 12 .5Z"></path>
          </svg>
        </span>
        <span class="contact-detail">
          <span>GitHub</span>
          <strong>github.com/marco-trento</strong>
        </span>
      </a>
    </div>
  </section>
</BaseLayout>
