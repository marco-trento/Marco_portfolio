---
interface Props {
  title: string;
  description: string;
  active?: 'home' | 'about' | 'blog' | 'contact';
}

const { title, description, active } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <style>
      html, body { background: #06090f; color: #e8eef9; }
    </style>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=Sora:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="container nav-wrap">
        <a class="brand" href="/">Marco Trento</a>
        <button class="nav-toggle" type="button" aria-expanded="false" aria-label="Toggle navigation">Menu</button>
        <nav class="site-nav" aria-label="Main navigation">
          <a class:list={[active === 'home' && 'active']} href="/">Home</a>
          <a class:list={[active === 'about' && 'active']} href="/about">About</a>
          <a class:list={[active === 'blog' && 'active']} href="/blog">Blog / Articles</a>
          <a class:list={[active === 'contact' && 'active']} href="/contact">Contact</a>
        </nav>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="container">© 2026 Marco Trento.</div>
    </footer>
    <script is:inline src="/js/main.js"></script>
  </body>
</html>
