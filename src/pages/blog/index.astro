---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const basePath = import.meta.env.BASE_URL;

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-GB', {
    day: '2-digit',
    month: 'short',
    year: 'numeric'
  });
---
<BaseLayout
  title="Blog / Articles | Marco Trento"
  description="Articles and technical notes by Marco Trento on physics, mathematics, computing, and scientific thinking."
  active="blog"
>
  <section class="section reveal" style="margin-top:0;">
    <h2>Blog / Articles</h2>
    <p class="page-intro">In this space I write about topics I am interested in.</p>

    {posts.length > 0 ? (
      <div class="post-list" style="margin-top: 1.1rem;">
        {posts.map((post) => (
          <a class="post-item" href={`${basePath}blog/${post.id}`}>
            <h3>{post.data.title}</h3>
            <div class="post-meta">
              <span>{formatDate(post.data.date)}</span>
              <span>{post.data.readTime}</span>
            </div>
            <p>{post.data.description}</p>
            <div class="tag-row">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state" style="margin-top: 1.1rem;">
        <h3>Articles are coming soon.</h3>
        <p>
          New notes about physics, mathematics, and scientific computing will
          appear here shortly.
        </p>
      </div>
    )}
  </section>
</BaseLayout>
